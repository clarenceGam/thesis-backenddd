              },
              "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "pm.test('HR login status 200', () => pm.response.to.have.status(200));",
                    "const j = pm.response.json();",
                    "pm.test('HR login success true', () => pm.expect(j.success).to.eql(true));",
                    "pm.collectionVariables.set('HR_TOKEN', j.data.token);",
                    "pm.test('HR_TOKEN saved', () => pm.expect(pm.collectionVariables.get('HR_TOKEN')).to.not.be.empty);"
                  ]
                }
              }
            ]
          },
