# ═══════════════════════════════════════════════════════════════
# PLATFORM BAR SYSTEM - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# ─── Database Configuration ───────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=bar_platform_db
DB_PORT=3306

# ─── Server Configuration ─────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT Configuration ────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── Application URLs ─────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── PayMongo Configuration ───────────────────────────────────
# Get your API keys from: https://dashboard.paymongo.com/developers/api-keys
# TEST KEYS (for development/testing)
PAYMONGO_PUBLIC_KEY=pk_test_REMOVED
PAYMONGO_SECRET_KEY=sk_test_REMOVED

# LIVE KEYS (for production - DO NOT commit these!)
# PAYMONGO_PUBLIC_KEY=pk_live_your_live_public_key_here
# PAYMONGO_SECRET_KEY=sk_live_your_live_secret_key_here

# PayMongo Webhook Secret (for verifying webhook signatures)
PAYMONGO_WEBHOOK_SECRET=whsk_REMOVED

# ─── Platform Settings ────────────────────────────────────────
# Platform fee percentage (applied to customer payments)
PLATFORM_FEE_PERCENTAGE=5.00

# ─── File Upload Configuration ────────────────────────────────
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg,image/gif

# ─── Email Configuration (Optional) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ─── Timezone Configuration ───────────────────────────────────
TZ=Asia/Manila

# ═══════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env (do not commit .env to git)
# 2. Update database credentials
# 3. Generate strong JWT_SECRET (use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# 4. Create PayMongo account at https://paymongo.com
# 5. Get test API keys from PayMongo dashboard
# 6. Run migration: node run_migration.js paymongo_payment_integration.sql
# 7. Update platform settings in database:
#    - paymongo_public_key
#    - paymongo_secret_key
#    - paymongo_webhook_secret
#    - platform_fee_percentage
#
# ═══════════════════════════════════════════════════════════════
